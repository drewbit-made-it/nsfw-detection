API_KEY=your-secret-key
MAX_IMAGE_MB=10  # default 10 MB, hard ceiling is 50 MB (use decimals for KB e.g. 0.5)
SERVERLESS=true  # true = low RAM/1 thread (serverless default); false = multi-core/pooled RAM
USE_INT8=false   # true = dynamic int8 quantization (faster on CPU, ~2-4x smaller model); false = float32
