API_KEY=your-secret-key
MAX_IMAGE_MB=10  # default 10 MB, hard ceiling is 50 MB (use decimals for KB e.g. 0.5)
SERVERLESS=true  # true = low RAM/1 thread (serverless default); false = multi-core/pooled RAM
USE_INT8=false  # true = int8 quantized model (faster CPU inference); false = float32
LOG_LEVEL=info   # info = per-request timing logs + uvicorn access logs; warning = warnings/errors only (recommended for high traffic)
